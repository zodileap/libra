{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Libra",
  "version": "0.1.5",
  "identifier": "com.libra.zodileap.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev:ui",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:ui",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Libra",
        "label": "main",
        "width": 1440,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist"
    },
    "resources": [
      "resources/skills"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://open.zodileap.com/libra/updates/latest.json"
      ]
    }
  }
}
