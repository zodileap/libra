      "program": "${workspaceFolder}/services/enterprise/cmd",
      "cwd": "${workspaceFolder}/services/enterprise",
      "buildFlags": "-tags=dev"
    }
  ],
  "compounds": [
    {
      "name": "Go Services: core(3-runnable)",
      "configurations": [
        "Go: account (dev)",
        "Go: runtime (dev)",
        "Go: agent_code (dev)"
      ]
    },
    {
      "name": "Go Services: all-runnable",
      "configurations": [
        "Go: account (dev)",
        "Go: runtime (dev)",
        "Go: agent_code (dev)",
        "Go: license (dev)",
        "Go: billing (dev)",
        "Go: enterprise (dev)"
      ]
    },
    {
      "name": "Go Services: include-agent_3d(experimental)",
      "configurations": [
        "Go: account (dev)",
        "Go: runtime (dev)",
        "Go: agent_code (dev)",
        "Go: agent_3d (dev)",
        "Go: license (dev)",
        "Go: billing (dev)",
        "Go: enterprise (dev)"
      ]
    }
  ]
}
