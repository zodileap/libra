{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Go: account (dev)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/services/account/cmd",
      "cwd": "${workspaceFolder}/services/account",
      "buildFlags": "-tags=dev"
    },
    {
      "name": "Go: runtime (dev)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/services/runtime/cmd",
      "cwd": "${workspaceFolder}/services/runtime",
      "buildFlags": "-tags=dev"
    },
    {
      "name": "Go: agent_code (dev)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/services/agent_code/cmd",
      "cwd": "${workspaceFolder}/services/agent_code",
      "buildFlags": "-tags=dev"
    },
    {
      "name": "Go: agent_3d (dev)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/services/agent_3d/cmd",
      "cwd": "${workspaceFolder}/services/agent_3d",
      "buildFlags": "-tags=dev"
    },
    {
      "name": "Go: license (dev)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/services/license/cmd",
      "cwd": "${workspaceFolder}/services/license",
      "buildFlags": "-tags=dev"
    },
    {
      "name": "Go: billing (dev)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
