{
  "name": "libra",
  "private": true,
  "version": "0.1.5",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm run dev:desktop",
    "dev:backend": "cd services && go run ./cmd/server",
    "dev:desktop": "pnpm --dir apps/desktop dev",
    "build:desktop": "pnpm --dir apps/desktop build",
    "package:desktop": "pnpm --dir apps/desktop package",
    "release:desktop": "node scripts/package-desktop-release.mjs",
    "bootstrap": "bash scripts/bootstrap.sh"
  }
}
